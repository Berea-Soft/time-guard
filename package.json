{
  "name": "@bereasoftware/time-guard",
  "private": false,
  "version": "2.4.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/time-guard.cjs",
  "module": "./dist/time-guard.es.js",
  "types": "./dist/types/time-guard.d.ts",
  "unpkg": "./dist/time-guard.umd.js",
  "browser": {
    "./dist/time-guard.umd.js": "./dist/time-guard.umd.js",
    "./dist/time-guard.iife.js": "./dist/time-guard.iife.js"
  },
  "exports": {
    ".": {
      "types": "./dist/types/time-guard.d.ts",
      "import": "./dist/time-guard.es.js",
      "require": "./dist/time-guard.cjs",
      "default": "./dist/time-guard.es.js"
    },
    "./locales": {
      "types": "./dist/types/locales/index.d.ts",
      "import": "./dist/locales/index.es.js",
      "require": "./dist/locales/index.cjs",
      "default": "./dist/locales/index.es.js"
    },
    "./calendars": {
      "types": "./dist/types/calendars/index.d.ts",
      "import": "./dist/calendars/index.es.js",
      "require": "./dist/calendars/index.cjs",
      "default": "./dist/calendars/index.es.js"
    },
    "./plugins/relative-time": {
      "types": "./dist/types/plugins/relative-time/index.d.ts",
      "import": "./dist/plugins/relative-time.es.js",
      "require": "./dist/plugins/relative-time.cjs",
      "default": "./dist/plugins/relative-time.es.js"
    },
    "./plugins/duration": {
      "types": "./dist/types/plugins/duration/index.d.ts",
      "import": "./dist/plugins/duration.es.js",
      "require": "./dist/plugins/duration.cjs",
      "default": "./dist/plugins/duration.es.js"
    },
    "./plugins/advanced-format": {
      "types": "./dist/types/plugins/advanced-format/index.d.ts",
      "import": "./dist/plugins/advanced-format.es.js",
      "require": "./dist/plugins/advanced-format.cjs",
      "default": "./dist/plugins/advanced-format.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "time-guard",
    "typescript",
    "date",
    "time",
    "temporal",
    "date-time",
    "datetime",
    "immutable",
    "locale",
    "i18n",
    "internationalization",
    "formatter",
    "date-formatter",
    "temporal-api",
    "solid-principles",
    "javascript"
  ],
  "author": "John Andrade <johnandrade@bereasoft.com>",
  "license": "MIT",
  "description": "A modern, fully-typed TypeScript date/time library built with the Temporal API, SOLID principles, and complete i18n support. Immutable, zero-dependencies, and designed for type safety.",
  "maintainers": [
    {
      "name": "John Andrade",
      "email": "johnandrade@bereasoft.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Berea-Soft/time-guard"
  },
  "bugs": {
    "url": "https://github.com/Berea-Soft/time-guard/issues"
  },
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.8.2"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not IE 11",
    "> 1%"
  ],
  "homepage": "https://github.com/Berea-Soft/time-guard#readme",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode umd",
    "build:all": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "lint:fix": "tsc --noEmit --pretty",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "peerDependenciesMeta": {
    "@js-temporal/polyfill": {
      "optional": true
    }
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "prettier": "^3.8.2",
    "semantic-release": "^25.0.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}

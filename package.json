{
  "name": "@bereasoftware/time-guard",
  "private": false,
  "version": "2.0.7",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/time-guard.cjs",
  "module": "./dist/time-guard.es.js",
  "types": "./dist/types/time-guard.d.ts",
  "unpkg": "./dist/time-guard.umd.js",
  "browser": {
    "./dist/time-guard.umd.js": "./dist/time-guard.umd.js",
    "./dist/time-guard.iife.js": "./dist/time-guard.iife.js"
  },
  "exports": {
    ".": {
      "types": "./dist/types/time-guard.d.ts",
      "browser": "./dist/time-guard.umd.js",
      "import": "./dist/time-guard.es.js",
      "require": "./dist/time-guard.cjs"
    },
    "./locales": {
      "types": "./dist/types/locales/index.d.ts",
      "import": "./dist/locales/index.es.js",
      "require": "./dist/locales/index.cjs"
    },
    "./calendars": {
      "types": "./dist/types/calendars/index.d.ts",
      "import": "./dist/calendars/index.es.js",
      "require": "./dist/calendars/index.cjs"
    },
    "./plugins/relative-time": {
      "types": "./dist/types/plugins/relative-time/index.d.ts",
      "import": "./dist/plugins/relative-time.es.js",
      "require": "./dist/plugins/relative-time.cjs"
    },
    "./plugins/duration": {
      "types": "./dist/types/plugins/duration/index.d.ts",
      "import": "./dist/plugins/duration.es.js",
      "require": "./dist/plugins/duration.cjs"
    },
    "./plugins/advanced-format": {
      "types": "./dist/types/plugins/advanced-format/index.d.ts",
      "import": "./dist/plugins/advanced-format.es.js",
      "require": "./dist/plugins/advanced-format.cjs"
    },
    "./umd": {
      "types": "./dist/types/time-guard.d.ts",
      "browser": "./dist/time-guard.umd.js",
      "import": "./dist/time-guard.umd.js",
      "require": "./dist/time-guard.umd.js"
    },
    "./iife": {
      "types": "./dist/types/time-guard.d.ts",
      "browser": "./dist/time-guard.iife.js",
      "import": "./dist/time-guard.iife.js",
      "require": "./dist/time-guard.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "time-guard",
    "typescript",
    "date",
    "time",
    "temporal",
    "date-time",
    "datetime",
    "immutable",
    "locale",
    "i18n",
    "internationalization",
    "formatter",
    "date-formatter",
    "temporal-api",
    "solid-principles",
    "javascript"
  ],
  "author": "John Andrade <johnandrade@bereasoft.com>",
  "license": "MIT",
  "description": "A modern, fully-typed TypeScript date/time library built with the Temporal API, SOLID principles, and complete i18n support. Immutable, zero-dependencies, and designed for type safety.",
  "maintainers": [
    {
      "name": "John Andrade",
      "email": "johnandrade@bereasoft.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Berea-Soft/time-guard"
  },
  "bugs": {
    "url": "https://github.com/Berea-Soft/time-guard/issues"
  },
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.8.2"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not IE 11",
    "> 1%"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode umd",
    "build:all": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "release": "standard-version",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "postrelease": "git push --follow-tags origin main && npm publish",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build:all"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/ui": "^4.0.18",
    "standard-version": "^9.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
